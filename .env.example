# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Database (Supabase PostgreSQL pooled connection, port 6543)
# Do NOT add SUPABASE_URL or SUPABASE_ANON_KEY — all DB access goes through Drizzle + DATABASE_URL
DATABASE_URL=

# GitHub Personal Access Token (read:user scope)
GITHUB_TOKEN=

# Cron job protection secret (random string)
CRON_SECRET=

# App URL (http://localhost:3000 in dev, production URL in prod)
NEXT_PUBLIC_APP_URL=

